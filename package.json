{
  "name": "airbnb-discovery-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:full": "concurrently -n db,app -c cyan,green \"docker compose up\" \"npm run dev\"",
    "setup": "docker compose up -d && sleep 3 && npm run db:seed",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "tsx scripts/seed-meilisearch.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:start": "docker run -d --name meilisearch -p 7700:7700 -e MEILI_MASTER_KEY=masterKey getmeili/meilisearch:latest",
    "db:stop": "docker stop meilisearch && docker rm meilisearch"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "bootstrap-icons": "^1.13.1",
    "maplibre-gl": "^5.24.0",
    "meilisearch": "^0.58.0",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
